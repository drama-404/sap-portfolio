{
  "_version": "1.76.0",
  "sap.app": {
    "id": "portfolio.sap.hr",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:alp",
      "version": "1.19.1",
      "toolsId": "ac29e97d-b955-432f-bedf-a1ad12702376"
    },
    "dataSources": {
      "mainService": {
        "uri": "/service/portfolio_service/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.141.3",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleUrl": "i18n/i18n.properties",
          "supportedLocales": [
            "en"
          ],
          "fallbackLocale": "en"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "ProjectTaskStatusAggList",
          "target": "ProjectTaskStatusAggList"
        },
        {
          "pattern": "ProjectTaskStatusAgg({key}):?query:",
          "name": "ProjectTaskStatusAggObjectPage",
          "target": "ProjectTaskStatusAggObjectPage"
        }
      ],
      "targets": {
        "ProjectTaskStatusAggList": {
          "type": "Component",
          "id": "ProjectTaskStatusAggList",
          "name": "sap.fe.templates.AnalyticalListPage",
          "options": {
            "settings": {
              "entitySet": "ProjectTaskStatusAgg",
              "annotationPath": "com.sap.vocabularies.UI.v1.PresentationVariant#Main",
              "variantManagement": "Page"
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "analytical"
  }
}